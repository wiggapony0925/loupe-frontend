# Loupe frontend — environment variables
# All vars must be prefixed EXPO_PUBLIC_ to be exposed to the client bundle.

EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_WS_URL=ws://localhost:8000

# OAuth client IDs (used by the Apple/Google SDKs to start the sign-in flow
# client-side; backend verifies the resulting token)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_APPLE_CLIENT_ID=
EXPO_PUBLIC_ENABLE_MOCK_BRIDGE=true
