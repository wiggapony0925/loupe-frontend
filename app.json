{
  "expo": {
    "name": "Loupe",
    "slug": "loupe",
    "scheme": "loupe",
    "description": "See every grain. Forensic card grading from the JFM Scanner.",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/86107c1a-082a-47d9-ba76-0aaaafe52090"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.loupe.client",
      "buildNumber": "85",
      "usesAppleSignIn": true,
      "entitlements": {
        "aps-environment": "production"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.714615078104-ta4c6j64ir3rqauqvf593q8llu8i2kr4"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "app.loupe.client",
      "adaptiveIcon": {
        "backgroundColor": "#121214"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-asset",
      "expo-font",
      "expo-updates",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Loupe needs camera access to capture cards for forensic grading.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Loupe uses your location to find this card for sale near you on Facebook Marketplace."
        }
      ],
      "expo-sharing",
      "@sentry/react-native",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0",
            "buildReactNativeFromSource": true
          }
        }
      ],
      "expo-web-browser",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "86107c1a-082a-47d9-ba76-0aaaafe52090"
      }
    },
    "owner": "jfmcapitalgroup"
  }
}
