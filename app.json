{
  "expo": {
    "name": "Loupe",
    "slug": "loupe",
    "scheme": "loupe",
    "description": "See every grain. Forensic card grading from the JFM Scanner.",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/86107c1a-082a-47d9-ba76-0aaaafe52090"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.loupe.client"
    },
    "android": {
      "package": "app.loupe.client",
      "adaptiveIcon": {
        "backgroundColor": "#121214"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "expo-updates",
      [
        "expo-camera",
        {
          "cameraPermission": "Loupe needs camera access to capture cards for forensic grading.",
          "recordAudioAndroid": false
        }
      ],
      "expo-sharing",
      "@sentry/react-native",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "86107c1a-082a-47d9-ba76-0aaaafe52090"
      }
    },
    "owner": "jfmcapitalgroup"
  }
}
