{
  "name": "loupe",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "kill": "kill-port 8081 19000 19001 19002 > /dev/null 2>&1; exit 0",
    "prestart": "npm run kill",
    "start": "expo start",
    "start:clean": "npm run kill && expo start --clear",
    "ios": "npm run kill && expo start --ios",
    "android": "npm run kill && expo start --android",
    "web": "npm run kill && expo start --web",
    "prebuild": "expo prebuild",
    "doctor": "npx expo-doctor",
    "fix-deps": "npx expo install --fix -- --legacy-peer-deps",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --cache --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx --cache --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "clean": "rm -rf .expo node_modules/.cache .tsbuildinfo && watchman watch-del-all 2>/dev/null || true"
  },
  "dependencies": {
    "@expo/html-elements": "^0.10.1",
    "@expo/vector-icons": "^15.0.2",
    "@gluestack-ui/core": "^3.0.20",
    "@gluestack-ui/utils": "^3.0.21",
    "@legendapp/motion": "^2.5.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@sentry/react-native": "~7.11.0",
    "@tanstack/react-query": "^5.59.0",
    "expo": "^55.0.24",
    "expo-asset": "~55.0.17",
    "expo-blur": "~55.0.14",
    "expo-camera": "~55.0.18",
    "expo-constants": "~55.0.16",
    "expo-font": "~55.0.7",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.10",
    "expo-image-manipulator": "~55.0.16",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-print": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-sharing": "~55.0.19",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.18",
    "lucide-react-native": "^0.460.0",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-aria": "^3.48.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4",
    "react-stately": "^3.46.0",
    "tailwind-variants": "^0.1.20",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/node": "^25.8.0",
    "@types/react": "~19.2.10",
    "eslint": "8.57.1",
    "eslint-config-expo": "~55.0.1",
    "kill-port": "^2.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  }
}
