{
  "name": "loupe",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "engines": {
    "node": ">=20.10.0"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "@react-native-ml-kit/text-recognition"
        ]
      }
    }
  },
  "scripts": {
    "kill": "kill-port 8081 19000 19001 19002 > /dev/null 2>&1; exit 0",
    "prestart": "npm run kill",
    "start": "expo start",
    "start:clean": "npm run kill && expo start --clear",
    "ios": "npm run kill && expo start --ios",
    "android": "npm run kill && expo start --android",
    "web": "npm run kill && expo start --web",
    "prebuild": "expo prebuild",
    "generate:set-logos": "node scripts/generate-set-logo-registry.mjs",
    "generate:api-types": "./scripts/generate-api-types.sh",
    "eas-build-pre-install": "node scripts/generate-set-logo-registry.mjs || true",
    "doctor": "npx expo-doctor",
    "fix-deps": "npx expo install --fix -- --legacy-peer-deps",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage",
    "test:integration": "vitest run",
    "test:integration:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx --cache --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx --cache --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "clean": "rm -rf .expo node_modules/.cache .tsbuildinfo && watchman watch-del-all 2>/dev/null || true",
    "sync:chart": "rm -rf vendor/loupe-chart/src && cp -R ../packages/chart/src vendor/loupe-chart/src && cp ../packages/chart/package.json vendor/loupe-chart/package.json",
    "sync:tokens": "rm -rf vendor/loupe-tokens/src && cp -R ../packages/tokens/src vendor/loupe-tokens/src && cp ../packages/tokens/package.json vendor/loupe-tokens/package.json",
    "sync:grade": "rm -rf vendor/loupe-grade/src && cp -R ../packages/grade/src vendor/loupe-grade/src && cp ../packages/grade/package.json vendor/loupe-grade/package.json",
    "sync:theme": "rm -rf vendor/loupe-theme/src && cp -R ../packages/theme/src vendor/loupe-theme/src && cp ../packages/theme/package.json vendor/loupe-theme/package.json",
    "storybook:dev": "storybook dev -p 7007"
  },
  "dependencies": {
    "@expo/html-elements": "^0.10.1",
    "@expo/vector-icons": "^15.0.2",
    "@gluestack-ui/core": "^3.0.20",
    "@gluestack-ui/utils": "^3.0.21",
    "@legendapp/motion": "^2.5.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.59.0",
    "expo": "~55.0.27",
    "expo-apple-authentication": "~55.0.14",
    "expo-asset": "~55.0.17",
    "expo-auth-session": "~55.0.17",
    "expo-blur": "~55.0.15",
    "expo-build-properties": "~55.0.15",
    "expo-camera": "~55.0.20",
    "expo-clipboard": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.16",
    "expo-device": "~55.0.18",
    "expo-font": "~55.0.7",
    "expo-glass-effect": "~55.0.11",
    "expo-haptics": "~55.0.15",
    "expo-image": "~55.0.11",
    "expo-image-manipulator": "~55.0.18",
    "expo-linear-gradient": "~55.0.15",
    "expo-linking": "~55.0.16",
    "expo-location": "~55.1.11",
    "expo-notifications": "~55.0.24",
    "expo-print": "~55.0.16",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.15",
    "expo-sharing": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.19",
    "expo-updates": "~55.0.25",
    "expo-web-browser": "~55.0.17",
    "jest-expo": "~55.0.19",
    "lucide-react-native": "^0.460.0",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-aria": "^3.48.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4",
    "react-stately": "^3.46.0",
    "tailwind-variants": "^0.1.20",
    "zod": "^4.4.3",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@storybook/react-native-web-vite": "^10.4.6",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "^25.8.0",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "8.57.1",
    "eslint-config-expo": "~55.0.1",
    "jest": "~29.7.0",
    "kill-port": "^2.0.1",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react-test-renderer": "^19.2.6",
    "storybook": "^10.4.6",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
