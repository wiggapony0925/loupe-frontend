{
  "name": "loupe",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "kill": "kill-port 8081 19000 19001 19002 > /dev/null 2>&1; exit 0",
    "prestart": "npm run kill",
    "start": "expo start",
    "start:clean": "npm run kill && expo start --clear",
    "ios": "npm run kill && expo start --ios",
    "android": "npm run kill && expo start --android",
    "web": "npm run kill && expo start --web",
    "prebuild": "expo prebuild",
    "doctor": "npx expo-doctor",
    "fix-deps": "npx expo install --fix -- --legacy-peer-deps",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --cache --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx --cache --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "clean": "rm -rf .expo node_modules/.cache .tsbuildinfo && watchman watch-del-all 2>/dev/null || true"
  },
  "dependencies": {
    "@expo/html-elements": "^0.10.1",
    "@expo/vector-icons": "~14.0.4",
    "@gluestack-ui/core": "^3.0.20",
    "@gluestack-ui/utils": "^3.0.21",
    "@legendapp/motion": "^2.5.3",
    "@tanstack/react-query": "^5.59.0",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-blur": "~14.0.1",
    "expo-camera": "~16.0.18",
    "expo-constants": "~17.0.8",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.0",
    "expo-image-manipulator": "~13.0.6",
    "expo-linear-gradient": "~14.0.1",
    "expo-linking": "~7.0.5",
    "expo-print": "~14.0.3",
    "expo-router": "~4.0.0",
    "expo-sharing": "~13.0.1",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.0",
    "lucide-react-native": "^0.460.0",
    "nativewind": "^4.2.3",
    "react": "18.3.1",
    "react-aria": "^3.48.0",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "react-stately": "^3.46.0",
    "tailwind-variants": "^0.1.20",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/node": "^25.8.0",
    "@types/react": "~18.3.12",
    "eslint": "8.57.1",
    "eslint-config-expo": "~8.0.1",
    "kill-port": "^2.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.6.3"
  }
}
